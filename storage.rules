rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // ============================================
    // USER PROFILE IMAGES (User-Owned)
    // ============================================
    
    // User profile images - only user can upload/delete own
    match /users/{userId}/{allPaths=**} {
      // ✅ All authenticated users can READ (profiles visible)
      allow read: if request.auth != null;
      
      // ✅ ONLY the user can WRITE their own images
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // ============================================
    // PRODUCT IMAGES (User-Owned)
    // ============================================
    
    // Product images - authenticated users can upload, only owner can delete
    match /products/{userId}/{allPaths=**} {
      // ✅ All authenticated users can READ product images
      allow read: if request.auth != null;
      
      // ✅ Authenticated users can WRITE their own products
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // ============================================
    // BAZAAR PRODUCT IMAGES (User-Owned)
    // ============================================
    
    // Bazaar product images - users can upload own, only owner can delete
    match /bazaar_products/{userId}/{allPaths=**} {
      // ✅ All authenticated users can READ bazaar images
      allow read: if request.auth != null;
      
      // ✅ ONLY the user can WRITE/DELETE their own images
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // ============================================
    // MACHINERY RENTAL IMAGES
    // ============================================
    
    // Machinery images - user-owned
    match /machinery/{userId}/{allPaths=**} {
      // ✅ All authenticated users can READ machinery images
      allow read: if request.auth != null;
      
      // ✅ ONLY owner can WRITE machinery images
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // ============================================
    // DISEASE DETECTION IMAGES (Private)
    // ============================================
    
    // Disease detection images - ONLY user can access
    match /disease-detection/{userId}/{allPaths=**} {
      // ✅ ONLY user can READ own disease detection images
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // ✅ ONLY user can WRITE own disease detection images
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // ============================================
    // SOIL ANALYSIS IMAGES (Private)
    // ============================================
    
    // Soil analysis images - ONLY user can access
    match /soil-analysis/{userId}/{allPaths=**} {
      // ✅ ONLY user can READ own soil analysis images
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // ✅ ONLY user can WRITE own soil analysis images
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // ============================================
    // ADMIN UPLOADS (Admin-Only)
    // ============================================
    
    // Admin resources - only admins can access
    match /admin/{allPaths=**} {
      // ✅ Only authenticated requests
      allow read, write: if request.auth != null;
    }
  }
}
