rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // ADMIN COLLECTIONS (Strict Access Control)
    // ============================================
    
    // Admin collection - only admins can access
    match /admins/{adminId} {
      // Allow authenticated users to read their own admin document (for login verification)
      // This is the most permissive rule to allow initial login without circular dependencies
      allow read: if request.auth != null && adminId == request.auth.uid;
      
      // Allow super admins to read all admin documents  
      allow read: if request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'super_admin';
      
      // Allow creating super_admin (first time) OR other admins by existing super admin
      allow create: if request.auth != null && (
        request.resource.data.role == 'super_admin' ||
        (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'super_admin' &&
         request.resource.data.role in ['admin', 'moderator'])
      );
      
      // Only super admin can update admins
      allow update: if request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'super_admin';
      
      // Only super admin can delete admins
      allow delete: if request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'super_admin';
    }

    // Admin logs - only admins can access
    match /admin_logs/{logId} {
      allow read, write: if request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role in ['super_admin', 'admin', 'moderator'];
    }
    
    // ============================================
    // USER PRIVATE DATA (Strict Isolation)
    // ============================================
    
    // User profiles - ONLY user can read/write their own profile
    match /users/{userId} {
      // ✅ User can ONLY read their own profile
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // ✅ User can ONLY create their own profile (during registration)
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // ✅ User can ONLY update their own profile
      allow update: if request.auth != null && request.auth.uid == userId;
      
      // ✅ User can delete their own profile
      allow delete: if request.auth != null && request.auth.uid == userId;
      
      // ✅ Admins can read and manage all users (for admin panel)
      allow read, update, delete: if request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // User wallets - ONLY user can read/write their own wallet
    match /wallets/{userId} {
      // ✅ User can ONLY read their own wallet (balance, income, earnings)
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // ✅ User can create their own wallet (during registration)
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // ✅ System (backend function) can update wallet on purchases
      allow update: if request.auth != null && request.auth.uid == userId;
      
      // ✅ User can delete their wallet (on account deletion)
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // User transactions - ONLY user can see their own transactions
    match /transactions/{transactionId} {
      // ✅ Read only own transactions
      allow read: if request.auth != null && 
        resource.data.userId == request.auth.uid;
      
      // ✅ Create own transactions
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid;
      
      // ✅ Cannot update transactions (immutable)
      allow update: if false;
      
      // ✅ Can delete own transactions
      allow delete: if request.auth != null && 
        resource.data.userId == request.auth.uid;
    }
    
    // ============================================
    // ORDERS & SALES (Privacy Protected)
    // ============================================
    
    // Orders - ONLY buyer and seller can see their orders
    match /orders/{orderId} {
      // ✅ Read only if you're the buyer or seller
      allow read: if request.auth != null && 
        (resource.data.buyerId == request.auth.uid || 
         resource.data.sellerId == request.auth.uid);
      
      // ✅ Create if you're the buyer
      allow create: if request.auth != null && 
        request.resource.data.buyerId == request.auth.uid;
      
      // ✅ Update if you're buyer or seller
      allow update: if request.auth != null && 
        (resource.data.buyerId == request.auth.uid || 
         resource.data.sellerId == request.auth.uid);
      
      // ✅ Admins can read all orders
      allow read: if request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // ============================================
    // PRODUCTS (Public Read, Private Write)
    // ============================================
    
    // Products (marketplace)
    match /products/{productId} {
      // Public read (anyone can see products)
      allow read: if request.auth != null;
      
      // Authenticated users can create
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid;
      
      // Only owner can edit/delete their products
      allow update, delete: if request.auth != null && 
        resource.data.userId == request.auth.uid;
      
      // Admins can manage all products
      allow update, delete: if request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // ============================================
    // MARKETPLACE COLLECTIONS (Public Read)
    // ============================================
    
    // Auctions - public but user-owned
    match /auctions/{auctionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && 
        resource.data.userId == request.auth.uid;
    }
    
    // Machinery rental
    match /machinery/{machineryId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && 
        resource.data.userId == request.auth.uid;
    }
    
    // Transport services
    match /transport/{transportId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && 
        resource.data.userId == request.auth.uid;
    }

    // Bazaar Products - Users can fully edit their own products
    match /bazaar_products/{productId} {
      // Authenticated users can read all bazaar products
      allow read: if request.auth != null;
      
      // Authenticated users can create their own products
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid;
      
      // Users can fully update/edit their own products (name, price, quantity, image)
      allow update: if request.auth != null && 
        resource.data.userId == request.auth.uid;
      
      // Users can delete only their own products
      allow delete: if request.auth != null && 
        resource.data.userId == request.auth.uid;
      
      // Admins can read, update and delete all products
      allow read, update, delete: if request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
  }
}
