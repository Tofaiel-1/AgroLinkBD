rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // ADMIN COLLECTIONS (Strict Access Control)
    // ============================================
    match /admins/{adminId} {
      // Merged: Allow read if user is reading their own admin doc OR if they are a super_admin
      allow read: if request.auth != null && (
        adminId == request.auth.uid || 
        (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'super_admin')
      );
      
      allow create: if request.auth != null && (
        request.resource.data.role == 'super_admin' ||
        (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'super_admin' &&
         request.resource.data.role in ['admin', 'moderator'])
      );
      
      allow update, delete: if request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'super_admin';
    }

    match /admin_logs/{logId} {
      allow read, write: if request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role in ['super_admin', 'admin', 'moderator'];
    }
    
    // ============================================
    // USER PRIVATE DATA (Strict Isolation)
    // ============================================
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
      // Admins override
      allow read, create, update, delete: if request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /wallets/{userId} {
      allow read, create, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    match /transactions/{transactionId} {
      allow get, list: if request.auth != null && 
        (resource.data.userId == request.auth.uid || 
         resource.data.senderUid == request.auth.uid ||
         resource.data.receiverUid == request.auth.uid ||
         exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
      
      allow create: if request.auth != null && 
        (request.resource.data.userId == request.auth.uid || 
         request.resource.data.senderUid == request.auth.uid ||
         exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
      
      allow update: if false;
      allow delete: if request.auth != null && 
        (resource.data.userId == request.auth.uid || resource.data.senderUid == request.auth.uid);
    }
    
    // ============================================
    // SOKOL CARD ECOSYSTEM & PAYMENTS
    // ============================================
    match /cards/{userId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
    }
    
    match /payment_requests/{requestId} {
      allow read: if request.auth != null && 
        (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.senderId == request.auth.uid;
      allow update: if request.auth != null && 
        (resource.data.receiverId == request.auth.uid || resource.data.senderId == request.auth.uid);
      allow delete: if false;
    }
    
    // ============================================
    // ORDERS & SALES (Privacy Protected)
    // ============================================
    match /orders/{orderId} {
      // Merged: Read only if buyer, seller, or admin
      allow read: if request.auth != null && 
        (resource.data.buyerId == request.auth.uid || 
         resource.data.sellerId == request.auth.uid ||
         exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
      
      allow create: if request.auth != null && request.resource.data.buyerId == request.auth.uid;
      
      allow update: if request.auth != null && 
        (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid);
    }
    
    // ============================================
    // PRODUCTS (Public Read, Private Write)
    // ============================================
    match /products/{productId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && 
        (resource.data.userId == request.auth.uid || exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }
    
    // ============================================
    // INVENTORY, REFUNDS, TRANSFERS & WITHDRAWS
    // ============================================
    match /inventory_products/{productId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /refund_requests/{requestId} {
      allow read: if request.auth != null && 
        (resource.data.userId == request.auth.uid || exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /deposit_requests/{requestId} {
      // NOTE: Warning! Left completely open as requested for testing.
      allow read, write: if true;
    }

    match /withdraw_requests/{requestId} {
      allow read: if request.auth != null && 
        (resource.data.userId == request.auth.uid || exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /transfer_requests/{requestId} {
      allow create: if request.auth != null && request.resource.data.senderId == request.auth.uid;
      allow read: if request.auth != null && 
        (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid || exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
      allow update, delete: if request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // ============================================
    // MARKETPLACE COLLECTIONS (Public Read)
    // ============================================
    match /auctions/{auctionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    match /machinery/{machineryId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    match /transport/{transportId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /bazaar_products/{productId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && 
        (resource.data.userId == request.auth.uid || exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }
    
    // ============================================
    // FARM MANAGEMENT
    // ============================================
    match /farms/{farmId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /crop_plantings/{plantingId} {
      allow read, create, update, delete: if request.auth != null;
    }

    match /user_audit_logs/{logId} {
      allow create: if true; 
      allow read, update: if request.auth != null && 
        (request.auth.uid == resource.data.userId || get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role in ['super_admin', 'admin']);
      allow delete: if request.auth != null && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'super_admin';
    }

    match /farm_activities/{activityId} {
      allow read, create, update, delete: if request.auth != null;
    }

    match /farm_expenses/{expenseId} {
      allow read, create, update, delete: if request.auth != null;
    }

    match /farm_revenues/{revenueId} {
      allow read, create, update, delete: if request.auth != null;
    }

    match /farm_inventory/{itemId} {
      allow read, create, update, delete: if request.auth != null;
    }

    // ============================================
    // MICROFINANCE & ANNOUNCEMENTS
    // ============================================
    match /announcements/{announcementId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /microfinance_applications/{applicationId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && 
        (resource.data.userId == request.auth.uid || exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
      allow update, delete: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // ============================================
    // RATINGS & PIN REQUESTS
    // ============================================
    match /ratings/{ratingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.raterUid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.raterUid == request.auth.uid;
    }
    
    match /pin_reset_requests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null; 
    }

    // ============================================
    // CATCH-ALL (CRITICAL FIX)
    // ============================================
    match /{document=**} {
      // Denies access to any document not explicitly defined above
      allow read, write: if false; 
    }  
  }
}